# Telegram API credentials (optional - can be added via UI in Settings > Telegram Accounts)
# Get from https://my.telegram.org/apps
# TELEGRAM_API_ID=your_api_id_here
# TELEGRAM_API_HASH=your_api_hash_here
# TELEGRAM_PHONE=+1234567890

# Ollama configuration
# Can be http://localhost:11434 or http://192.168.1.6:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Autonomous agent mode (self-healing, dynamic scheduling, source discovery)
# Set to true to enable the autonomous orchestrator on startup
ENABLE_AUTONOMOUS_MODE=false

# Ollama daily token budget for autonomous healing/discovery (default: 100000)
# AUTONOMOUS_OLLAMA_BUDGET=100000

# ── AI Provider Configuration ────────────────────────────────────────────────
# ANALYZE_PROVIDER: provider used to classify Telegram/RSS messages
#   "ollama"  — local Ollama (default, no API key needed)
#   "nvidia"  — NVIDIA NIM API (requires NVIDIA_API_KEY)
ANALYZE_PROVIDER=ollama

# RESUME_PROVIDER: provider used for Generate / Enhance / Score resume features
#   "nvidia"  — NVIDIA NIM API (default, requires NVIDIA_API_KEY)
#   "ollama"  — local Ollama
RESUME_PROVIDER=nvidia

# NVIDIA NIM API key — required when ANALYZE_PROVIDER=nvidia or RESUME_PROVIDER=nvidia
# Free key: https://build.nvidia.com  or  https://github.com/Alishahryar1/free-claude-code
NVIDIA_API_KEY=

# NVIDIA model to use for both analysis and resume features (optional override)
# Default: qwen/qwen3.5-397b-a17b
# NVIDIA_MODEL=qwen/qwen3.5-397b-a17b
# ─────────────────────────────────────────────────────────────────────────────