# API Base URL
# Leave empty for same-domain requests (production with FastAPI serving static files)
# For local development: http://localhost:8000
# For ngrok: https://your-ngrok-url.ngrok-free.app
VITE_API_BASE_URL=

# WebSocket Base URL
# Leave empty for same-domain requests (production with FastAPI serving static files)
# For local development: ws://localhost:8000/ws/progress
# For ngrok: wss://your-ngrok-url.ngrok-free.app/ws/progress
VITE_WS_BASE_URL=
