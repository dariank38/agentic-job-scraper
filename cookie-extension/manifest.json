{
  "manifest_version": 3,
  "name": "Bossjob Cookie Exporter",
  "version": "1.0.0",
  "description": "Export bossjob.com cookies to your job scraper dashboard",
  "permissions": [
    "cookies",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://bossjob.com/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
